# ============================================================================
# POLYMARKET INSIDER TRADING DETECTION SYSTEM
# Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values

# ============================================================================
# DATABASE CONNECTION
# ============================================================================
DATABASE_URL=postgresql://postgres:password@localhost:5432/polymarket

# ============================================================================
# API ENDPOINTS
# ============================================================================
# Polymarket Gamma API (Market context)
POLYMARKET_GAMMA_API=https://gamma-api.polymarket.com/markets?active=true&closed=false

# Polymarket CLOB WebSocket (Real-time trades)
POLYMARKET_CLOB_WS=wss://ws-subscriptions-clob.polymarket.com/ws/market

# Polygon RPC (Blockchain queries)
POLYGON_RPC_WSS=wss://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ============================================================================
# OPERATIONAL CIRCUIT BREAKERS
# ============================================================================
# Minimum trade size in USD to process
MIN_USD_PER_TRADE=1000

# Maximum trade size in USD to process
MAX_USD_PER_TRADE=500000

# Maximum number of signals to send per day
DAILY_SIGNAL_LIMIT=3

# ============================================================================
# BASELINE MATH (WELFORD OUTLIER DETECTION)
# ============================================================================
# Percentage of CLOB liquidity that excludes a trade from baseline math (0.05 = 5%)
WELFORD_OUTLIER_PCT=0.05

# Hours a market must be active before baseline is considered stable
BURN_IN_HOURS=72

# Minimum trades before baseline is considered stable
BURN_IN_MIN_TRADES=1000

# Z-score threshold for triggering anomaly detection
Z_SCORE_TRIGGER=3.0

# ============================================================================
# BEHAVIORAL FORENSICS
# ============================================================================
# Nonce threshold below which a wallet is considered "burner"
BURNER_NONCE_LIMIT=5

# Nonce threshold above which a wallet is considered "established"
ESTABLISHED_NONCE_LIMIT=50

# Target flow ratio for "just-in-time funding" detection (0.90 = 90%)
FLOW_RATIO_TARGET=0.90

# Number of Polygon blocks to look back for flow ratio (7200 ≈ 4 hours)
FLOW_RATIO_LOOKBACK_BLOCKS=7200

# Days of inactivity before a wallet is considered "dormant"
DORMANCY_DAYS=30

# ============================================================================
# CLUSTER INTELLIGENCE
# ============================================================================
# Time window in minutes for grouping related trades
CLUSTER_WINDOW_MINUTES=15

# Number of trades in window to trigger cluster alert
CLUSTER_TRIGGER_COUNT=3

# Hours to wait before alerting on same market again
MARKET_COOLDOWN_HOURS=12

# Minimum trade size in USD to bypass uncalibrated baseline requirement
EARLY_MARKET_BYPASS_USD=25000

# Multiplier for cluster alert debounce (1.25 = 25% increase required)
CLUSTER_DEBOUNCE_MULTIPLIER=1.25

# ============================================================================
# TELEGRAM NOTIFICATIONS
# ============================================================================
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram chat ID (use @userinfobot to find it)
TELEGRAM_CHAT_ID=your_chat_id_here

# Optional: Telegram thread ID for organizing messages
TELEGRAM_THREAD_ID=

# ============================================================================
# HEARTBEAT & HEALTH MONITORING
# ============================================================================
# Enable/disable periodic heartbeat notifications (true/false)
HEARTBEAT_ENABLED=true

# Interval between heartbeat notifications in minutes
HEARTBEAT_INTERVAL_MINUTES=30

# ============================================================================
# ENHANCED TELEGRAM LOGGING
# ============================================================================
# Log WebSocket connection events to Telegram
LOG_STREAM_EVENTS=false

# Log market context refresh events to Telegram
LOG_CONTEXT_UPDATES=false

# Log market baseline calibration events to Telegram
LOG_BASELINE_CALIBRATION=false

# Log database batch flush operations to Telegram
LOG_DB_FLUSHES=false

# Log blockchain RPC activity to Telegram
LOG_RPC_CALLS=false

# Log all signals (not just confirmed insiders) to Telegram
LOG_ALL_SIGNALS=false

# Only log errors to Telegram (overrides other flags if true)
LOG_ERRORS_ONLY=false

# ============================================================================
# CONNECTION HEALTH THRESHOLDS
# ============================================================================
# Alert after N consecutive WebSocket reconnection attempts
WEBSOCKET_RECONNECT_ALERT=3

# Alert after N consecutive API failure attempts
API_FAILURE_ALERT_THRESHOLD=3

# ============================================================================
# PROXY CONFIGURATION
# ============================================================================
# For geobypass - Set if Polymarket is blocked in your region
# Example: socks5://127.0.0.1:1080
HTTPS_PROXY=socks5://127.0.0.1:1080
HTTP_PROXY=socks5://127.0.0.1:1080

# ============================================================================
# EXTERNAL API KEYS
# ============================================================================
# Get your API key from https://polygonscan.com/
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here
